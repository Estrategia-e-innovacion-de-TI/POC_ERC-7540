# Example environment variables for deployment
# Copy this file to .env and replace placeholder values.

# Required for Sepolia deployment commands in Makefile
BLOCKCHAIN_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_API_KEY
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Optional values used by DeployERC4626IdleVault.s.sol
# ASSET_TOKEN must be a valid ERC20 address on the target network.
ASSET_TOKEN=0x0000000000000000000000000000000000000000
VAULT_NAME=Vault COPW
VAULT_SYMBOL=vCOPW
